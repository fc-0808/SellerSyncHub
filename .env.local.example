# SellerSyncHub — environment variable template
#
# Copy to `.env` (recommended for this repo) or `.env.local` in the project root.
# Both are gitignored except this example file. Never commit real secrets.
# Production site URL (OG metadata, sitemap, robots). On Vercel, set to your live domain.
NEXT_PUBLIC_SITE_URL=https://sellersynchub.com

# ─── Etsy OAuth callback (must match Developer Portal exactly) ───────────────
# In Etsy → Your Apps → Edit app → Callback URLs, register BOTH (no trailing slash):
#   http://localhost:3000/api/oauth/callback     ← local `next dev` (default port 3000)
#   https://sellersynchub.com/api/oauth/callback
#
# Normally leave ETSY_OAUTH_REDIRECT_URI unset: the app uses the current request
# origin + `/api/oauth/callback` so localhost and production match the URLs above.
# Only set this if you must force one URL (e.g. custom port or reverse proxy).
# ETSY_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API (or API Settings → Secret / Publishable keys)
#
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
#
# Secret key (sb_secret_…) — server only. Also accepted as SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here
# SUPABASE_SECRET_KEY=your-service-role-secret-key-here
#
# Optional — publishable key (sb_publishable_…) for future browser client + RLS
# SUPABASE_ANON_KEY=your-publishable-key-here

# ─── Etsy Open API v3 (server-side only) ─────────────────────────────────────
# From Etsy Developer Portal → Personal Apps (or Your Apps) → Keystring + Shared Secret.
# NEVER commit real values — copy this file to `.env.local` and paste secrets there only.
# `.env.local` is gitignored via `.env*`.
ETSY_API_KEYSTRING=your-keystring-here
ETSY_API_SHARED_SECRET=your-shared-secret-here
#
# Space-separated scopes for OAuth (defaults in code: shops_r transactions_r listings_r)
# ETSY_OAUTH_SCOPES=shops_r transactions_r listings_r
