# ─── Site ─────────────────────────────────────────────────────────────────────
# Full URL of your deployment — used for OG metadata, sitemap, and robots.txt
NEXT_PUBLIC_SITE_URL=https://sellersynchub.com

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
#
# Project URL (safe to expose; used server-side only in this project)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
#
# Service Role key — NEVER expose in client-side code or commit to git
# Used only in app/api/waitlist/route.ts (server-side Route Handler)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
